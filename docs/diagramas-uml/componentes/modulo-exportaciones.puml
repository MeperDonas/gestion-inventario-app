@startuml
!define RECTANGLE class

skinparam backgroundColor #FEFEFE
skinparam handwritten false
skinparam componentStyle rectangle

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontSize 12
}

skinparam interface {
    BackgroundColor #FFF3E0
    BorderColor #F57C00
}

title Diagrama de Componentes - Módulo de Exportaciones

package "Módulo de Exportaciones" {
    
    [ExportsController] as ExpCtrl #E3F2FD
    [ExportsService] as ExpSvc #E8F5E9
    
    package "DTOs" {
        [ExportFilterDto] as FilterDto #F3E5F5
        [ExportFormatDto] as FormatDto #F3E5F5
    }
    
    package "Formatos de Exportación" {
        [PDFGenerator] as PDF #E1F5FE
        [ExcelGenerator] as Excel #E1F5FE
        [CSVGenerator] as CSV #E1F5FE
    }
}

package "Dependencias Externas" {
    [PrismaService] as Prisma #E0E0E0
    [CloudinaryService] as Cloud #E0E0E0
    database "PostgreSQL" as DB #BBDEFB
    storage "Cloudinary CDN" as CDN #FFE0B2
}

package "Endpoints REST" {
    () "GET /exports/sales" as E1
    () "GET /exports/products" as E2
    () "GET /exports/customers" as E3
    () "GET /exports/inventory" as E4
}

' Conexiones entre componentes
E1 --> ExpCtrl
E2 --> ExpCtrl
E3 --> ExpCtrl
E4 --> ExpCtrl

ExpCtrl --> ExpSvc

ExpSvc --> FilterDto
ExpSvc --> FormatDto

ExpSvc --> Prisma
ExpSvc --> Cloud

' Generadores
ExpSvc --> PDF
ExpSvc --> Excel
ExpSvc --> CSV

Prisma --> DB
Cloud --> CDN

note right of ExpCtrl
    **ExportsController**
    @Controller('exports')
    Exportación de datos
    en múltiples formatos
end note

note right of ExpSvc
    **ExportsService**
    @Injectable()
    Generación de archivos:
    - PDF (facturas, reportes)
    - Excel (datos tabulares)
    - CSV (exportación masiva)
    - Almacenamiento en Cloud
end note

legend right
    |= Color |= Tipo de Componente |
    | <#E3F2FD> | Controller (API) |
    | <#E8F5E9> | Service (Lógica) |
    | <#F3E5F5> | DTOs |
    | <#E0E0E0> | Servicios externos |
    | <#BBDEFB> | Base de Datos |
    | <#FFE0B2> | Almacenamiento |
    | <#E1F5FE> | Generadores |
endlegend

@enduml
