@startuml Diagrama de Casos de Uso - Sistema de Gestion de Inventario y POS

!define RECTANGLE class

skinparam backgroundColor #FEFEFE
skinparam handwritten false

skinparam usecase {
    BackgroundColor<<include>> LightGreen
    BorderColor<<include>> DarkGreen
    BackgroundColor<<extend>> LightBlue
    BorderColor<<extend>> DarkBlue
    ArrowColor Black
    ActorBorderColor Black
    ActorBackgroundColor #E0E0E0
}

skinparam package {
    BackgroundColor<<Modulo>> LightYellow
    BorderColor<<Modulo>> Orange
}

title Diagrama de Casos de Uso - Sistema de Gestion de Inventario y Punto de Venta

' Actores
left to right direction

actor "Administrador" as Admin #LightCoral
actor "Cajero" as Cajero #LightBlue
actor "Usuario de\nInventario" as InvUser #LightGreen

' Modulo de Autenticacion
package "Modulo de Autenticacion" <<Modulo>> {
    usecase "UC01: Iniciar Sesion" as UC01
    usecase "UC02: Cerrar Sesion" as UC02
    usecase "UC03: Registrar Usuario" as UC03
    usecase "UC04: Recuperar Contrasena" as UC04
    usecase "UC05: Editar Perfil" as UC05
}

' Modulo de Productos
package "Modulo de Productos" <<Modulo>> {
    usecase "UC06: Crear Producto" as UC06
    usecase "UC07: Editar Producto" as UC07
    usecase "UC08: Eliminar Producto" as UC08
    usecase "UC09: Consultar Productos" as UC09
    usecase "UC10: Buscar Productos" as UC10
    usecase "UC11: Gestionar Stock" as UC11
    usecase "UC12: Subir Imagen" as UC12
}

' Modulo de Categorias
package "Modulo de Categorias" <<Modulo>> {
    usecase "UC13: Crear Categoria" as UC13
    usecase "UC14: Editar Categoria" as UC14
    usecase "UC15: Eliminar Categoria" as UC15
    usecase "UC16: Consultar Categorias" as UC16
}

' Modulo de Clientes
package "Modulo de Clientes" <<Modulo>> {
    usecase "UC17: Crear Cliente" as UC17
    usecase "UC18: Editar Cliente" as UC18
    usecase "UC19: Eliminar Cliente" as UC19
    usecase "UC20: Consultar Clientes" as UC20
    usecase "UC21: Buscar Cliente" as UC21
}

' Modulo de Ventas/POS
package "Modulo de Ventas/POS" <<Modulo>> {
    usecase "UC22: Crear Venta" as UC22
    usecase "UC23: Procesar Pago" as UC23 #LightGreen
    usecase "UC24: Aplicar Descuento" as UC24 #LightBlue
    usecase "UC25: Consultar Ventas" as UC25
    usecase "UC26: Ver Detalle de Venta" as UC26
    usecase "UC27: Cancelar Venta" as UC27
    usecase "UC28: Pausar Venta" as UC28 #LightBlue
    usecase "UC29: Reanudar Venta" as UC29
    usecase "UC30: Generar Factura" as UC30
}

' Modulo de Reportes
package "Modulo de Reportes" <<Modulo>> {
    usecase "UC31: Ver Dashboard" as UC31
    usecase "UC32: Generar Reporte\nde Ventas" as UC32
    usecase "UC33: Generar Reporte\nde Productos" as UC33
    usecase "UC34: Generar Reporte\nde Clientes" as UC34
    usecase "UC35: Estadisticas\nde Inventario" as UC35
}

' Modulo de Exportaciones
package "Modulo de Exportaciones" <<Modulo>> {
    usecase "UC36: Exportar Ventas" as UC36
    usecase "UC37: Exportar Productos" as UC37
    usecase "UC38: Exportar Clientes" as UC38
    usecase "UC39: Exportar Inventario" as UC39
}

' Modulo de Configuracion
package "Modulo de Configuracion" <<Modulo>> {
    usecase "UC40: Configurar Empresa" as UC40
    usecase "UC41: Configurar Impuestos" as UC41
    usecase "UC42: Gestionar Usuarios" as UC42
    usecase "UC43: Cambiar Tema" as UC43
}

' Modulo de Auditoria
package "Modulo de Auditoria" <<Modulo>> {
    usecase "UC44: Ver Logs\nde Auditoria" as UC44
    usecase "UC45: Consultar Movimientos\nde Inventario" as UC45
}

' Relaciones de Administrador (todos los casos de uso)
Admin --> UC01
Admin --> UC02
Admin --> UC03
Admin --> UC04
Admin --> UC05
Admin --> UC06
Admin --> UC07
Admin --> UC08
Admin --> UC09
Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --> UC19
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23
Admin --> UC24
Admin --> UC25
Admin --> UC26
Admin --> UC27
Admin --> UC28
Admin --> UC29
Admin --> UC30
Admin --> UC31
Admin --> UC32
Admin --> UC33
Admin --> UC34
Admin --> UC35
Admin --> UC36
Admin --> UC37
Admin --> UC38
Admin --> UC39
Admin --> UC40
Admin --> UC41
Admin --> UC42
Admin --> UC43
Admin --> UC44
Admin --> UC45

' Relaciones de Cajero (solo funciones de venta)
Cajero --> UC01
Cajero --> UC02
Cajero --> UC05
Cajero --> UC09
Cajero --> UC10
Cajero --> UC17
Cajero --> UC18
Cajero --> UC20
Cajero --> UC21
Cajero --> UC22
Cajero --> UC23
Cajero --> UC24
Cajero --> UC25
Cajero --> UC26
Cajero --> UC28
Cajero --> UC29
Cajero --> UC30
Cajero --> UC31
Cajero --> UC43

' Relaciones de Usuario de Inventario
InvUser --> UC01
InvUser --> UC02
InvUser --> UC05
InvUser --> UC06
InvUser --> UC07
InvUser --> UC09
InvUser --> UC10
InvUser --> UC11
InvUser --> UC12
InvUser --> UC13
InvUser --> UC14
InvUser --> UC16
InvUser --> UC35
InvUser --> UC37
InvUser --> UC39
InvUser --> UC43
InvUser --> UC45

' Relaciones <<include>> (obligatorias)
UC22 ..> UC23 : <<include>>
UC22 ..> UC09 : <<include>>
UC27 ..> UC11 : <<include>>
UC06 ..> UC16 : <<include>>
UC17 ..> UC21 : <<include>>

' Relaciones <<extend>> (opcionales)
UC24 ..> UC22 : <<extend>>
UC28 ..> UC22 : <<extend>>
UC12 ..> UC07 : <<extend>>

note right of UC22
  **Flujo de Venta:**
  1. Agregar productos
  2. Seleccionar cliente
  3. Aplicar descuento (opc)
  4. Pausar venta (opc)
  5. Procesar pago
  6. Generar factura
end note

note bottom of Admin
  **Rol: Administrador**
  Acceso total a todas
  las funcionalidades
  del sistema
end note

note bottom of Cajero
  **Rol: Cajero**
  Enfocado en operaciones
  de venta y atencion
  al cliente
end note

note bottom of InvUser
  **Rol: Inventario**
  Gestion de productos,
  stock y categorias
end note

legend right
  |= Color |= Significado |
  | <back:LightGreen>     | <<include>> Relacion obligatoria |
  | <back:LightBlue>      | <<extend>> Relacion opcional    |
  | <back:LightYellow>    | Modulo del sistema              |
endlegend

@enduml
