@startuml
!define RECTANGLE class

skinparam backgroundColor #FEFEFE
skinparam handwritten false
skinparam componentStyle rectangle

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontSize 12
}

skinparam interface {
    BackgroundColor #FFF3E0
    BorderColor #F57C00
}

title Diagrama de Componentes - Módulo de Configuración

package "Módulo de Configuración" {
    
    [SettingsController] as SetCtrl #E3F2FD
    [SettingsService] as SetSvc #E8F5E9
    
    package "DTOs" {
        [UpdateSettingsDto] as UpdateDto #F3E5F5
        [CompanySettingsDto] as CompDto #F3E5F5
        [TaxSettingsDto] as TaxDto #F3E5F5
    }
}

package "Dependencias Externas" {
    [PrismaService] as Prisma #E0E0E0
    [CacheService] as Cache #E0E0E0
    [CloudinaryService] as Cloud #E0E0E0
    database "PostgreSQL" as DB #BBDEFB
    storage "Cloudinary CDN" as CDN #FFE0B2
}

package "Endpoints REST" {
    () "GET /settings" as E1
    () "PUT /settings" as E2
    () "POST /settings/logo" as E3
    () "GET /settings/tax" as E4
    () "PUT /settings/tax" as E5
}

package "Configuraciones" {
    component "Datos Empresa" as C1 #E1F5FE
    component "Impuestos" as C2 #E1F5FE
    component "Generación de Recibos" as C3 #E1F5FE
    component "Usuarios" as C4 #E1F5FE
}

' Conexiones entre componentes
E1 --> SetCtrl
E2 --> SetCtrl
E3 --> SetCtrl
E4 --> SetCtrl
E5 --> SetCtrl

SetCtrl --> SetSvc

SetSvc --> UpdateDto
SetSvc --> CompDto
SetSvc --> TaxDto

SetSvc --> Prisma
SetSvc --> Cache
SetSvc --> Cloud

' Configuraciones
SetSvc --> C1
SetSvc --> C2
SetSvc --> C3
SetSvc --> C4

Prisma --> DB
Cloud --> CDN

note right of SetCtrl
    **SettingsController**
    @Controller('settings')
    Configuración general
del sistema
end note

note right of SetSvc
    **SettingsService**
    @Injectable()
    Gestión de configuraciones:
    - Datos de empresa
    - Configuración fiscal
    - Parámetros de recibo
    - Gestión de usuarios
    - Caché de settings
end note

legend right
    |= Color |= Tipo de Componente |
    | <#E3F2FD> | Controller (API) |
    | <#E8F5E9> | Service (Lógica) |
    | <#F3E5F5> | DTOs |
    | <#E0E0E0> | Servicios externos |
    | <#BBDEFB> | Base de Datos |
    | <#FFE0B2> | Almacenamiento |
    | <#E1F5FE> | Configuraciones |
endlegend

@enduml
