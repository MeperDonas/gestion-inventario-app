@startuml

skinparam backgroundColor #FEFEFE
skinparam handwritten false

title Diagrama de Secuencia - Flujo de Venta (POS)

actor "Cajero" as Cajero
participant "Frontend\n(Next.js)" as Frontend
participant "SalesController\n(NestJS)" as Ctrl
participant "SalesService\n(NestJS)" as Svc
participant "PrismaService" as Prisma
database "PostgreSQL" as DB
participant "Cloudinary" as Cloud

== Fase 1: Iniciar Venta ==
Cajero -> Frontend: 1. Iniciar nueva venta
activate Frontend

== Fase 2: Buscar y Agregar Productos ==
Cajero -> Frontend: 2. Buscar producto
Frontend -> Ctrl: GET /products/search?q={query}
Ctrl -> Svc: searchProducts(query)
Svc -> Prisma: findMany({ where: {...} })
Prisma -> DB: SELECT * FROM products
DB --> Prisma: Resultados
Prisma --> Svc: Productos[]
Svc --> Ctrl: Productos[]
Ctrl --> Frontend: 200 OK + Productos
Frontend --> Cajero: Mostrar resultados

Cajero -> Frontend: 3. Agregar producto al carrito
Frontend -> Frontend: Verificar stock local
alt Stock suficiente
    Frontend -> Frontend: Agregar a carrito[]
    Frontend --> Cajero: Producto agregado
else Stock insuficiente
    Frontend --> Cajero: Error: Stock no disponible
end

== Fase 3: Seleccionar Cliente (Opcional) ==
Cajero -> Frontend: 4. Buscar cliente
Frontend -> Ctrl: GET /customers/search?q={doc}
Ctrl --> Frontend: 200 OK + Cliente
Frontend --> Cajero: Cliente asignado

== Fase 4: Aplicar Descuento (Opcional) ==
Cajero -> Frontend: 5. Aplicar descuento
Frontend -> Frontend: Calcular totales
Frontend --> Cajero: Total actualizado

== Fase 5: Pausar/Reanudar Venta ==
opt Venta pausada
    Cajero -> Frontend: 6. Pausar venta
    Frontend -> Frontend: Guardar en localStorage
    Frontend --> Cajero: Venta pausada
    
    Cajero -> Frontend: 7. Reanudar venta
    Frontend -> Frontend: Cargar de localStorage
    Frontend --> Cajero: Venta restaurada
end

== Fase 6: Procesar Pago ==
Cajero -> Frontend: 8. Procesar pago
Frontend -> Frontend: Calcular cambio
Frontend --> Cajero: Mostrar resumen de pago

== Fase 7: Confirmar Venta (Transacción) ==
Cajero -> Frontend: 9. Confirmar venta
Frontend -> Ctrl: POST /sales
activate Ctrl

Ctrl -> Svc: createSale(dto)
activate Svc

note right of Svc
    **Inicio Transacción ACID**
    prisma.$transaction(async (tx) => {
end note

Svc -> Prisma: $transaction.begin()

loop Por cada item en la venta
    Svc -> Prisma: tx.product.findUnique()
    Prisma -> DB: SELECT stock FROM products
    DB --> Prisma: stock
    Prisma --> Svc: Producto
    
    alt Stock suficiente
        Svc -> Prisma: tx.product.update()
        Prisma -> DB: UPDATE products SET stock = stock - qty
        DB --> Prisma: OK
        
        Svc -> Prisma: tx.inventoryMovement.create()
        Prisma -> DB: INSERT INTO inventory_movements
        DB --> Prisma: OK
    else Stock insuficiente
        Svc -> Prisma: $transaction.rollback()
        Prisma --> Svc: Error: Stock insuficiente
        Svc --> Ctrl: Throw BadRequestException
        Ctrl --> Frontend: 400 Bad Request
        Frontend --> Cajero: Error: Stock insuficiente
    end
end

Svc -> Svc: Calcular subtotal, impuestos, total

Svc -> Prisma: tx.sale.create()
Prisma -> DB: INSERT INTO sales
DB --> Prisma: Venta creada
Prisma --> Svc: Sale

Svc -> Prisma: tx.saleItem.createMany()
Prisma -> DB: INSERT INTO sale_items
DB --> Prisma: OK

Svc -> Prisma: tx.payment.createMany()
Prisma -> DB: INSERT INTO payments
DB --> Prisma: OK

Svc -> Prisma: $transaction.commit()
Prisma --> Svc: Transacción completada

note right of Svc
    **Fin Transacción**
    Todos los cambios
    persistidos o ninguno
end note

Svc --> Ctrl: Sale creada
deactivate Svc

Ctrl -> Cloud: Generar recibo PDF
Cloud --> Ctrl: URL del PDF

Ctrl --> Frontend: 201 Created + Sale + PDF_URL
deactivate Ctrl

Frontend --> Cajero: Venta completada
Frontend --> Cajero: Mostrar recibo PDF

== Fase 8: Cancelar Venta (Rollback) ==
opt Cancelación de venta
    Cajero -> Frontend: Cancelar venta
    Frontend -> Ctrl: POST /sales/{id}/cancel
    Ctrl -> Svc: cancelSale(id)
    
    Svc -> Prisma: $transaction()
    Svc -> Prisma: tx.sale.update({ status: CANCELLED })
    
    loop Por cada item
        Svc -> Prisma: tx.product.update()
        Prisma -> DB: UPDATE products SET stock = stock + qty
        Svc -> Prisma: tx.inventoryMovement.create()
    end
    
    Prisma --> Svc: Venta cancelada
    Svc --> Ctrl: Sale cancelada
    Ctrl --> Frontend: 200 OK
    Frontend --> Cajero: Venta cancelada exitosamente
end

deactivate Frontend

@enduml
